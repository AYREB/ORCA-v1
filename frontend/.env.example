# Frontend build-time configuration (Vite).
# Copy to .env (or .env.production) and set before building/deploying.
# NOTE: Vite inlines these at BUILD time, not runtime — you must rebuild after changing them.

# Base URL of the Django API. Must include the trailing /api.
# Defaults to http://127.0.0.1:8000/api when unset (local dev only).
VITE_DJANGO_API_URL=https://your-backend-host.example.com/api

# Google OAuth client id for "Sign in with Google".
# When unset, the Google sign-in button is hidden.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
