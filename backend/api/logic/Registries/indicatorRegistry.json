{
    "INDICATORS": {
        "PRICE": {
        "function": "get_price",
        "args": ["field", "offset"],
        "defaults": {"field": "close", "offset": 0}
        },
        "VOLUME": {
        "function": "get_volume",
        "args": ["offset"],
        "defaults": {"offset": 0}
        },
        "SMA": {
            "function": "compute_sma",
            "args": ["period", "timeframe"],
            "defaults": {"period": 14, "timeframe":"1h"},
            "supports_timeframe": true 
        },
        "EMA": {
            "function": "compute_ema",
            "args": ["period", "timeframe"],
            "defaults": {"period": 14},
            "supports_timeframe": true
        },
        "RSI": {
            "function": "compute_rsi",
            "args": ["period", "timeframe"],              
            "defaults": {"period": 14, "timeframe":"1h"},      
            "supports_timeframe": true    
        },   
        "MACD": {
            "function": "compute_macd",
            "args": ["fast", "slow", "signal", "timeframe"],
            "defaults": {"fast": 12, "slow": 26, "signal": 9, "timeframe":"1h"},
            "supports_timeframe": true
        }
    }
}
